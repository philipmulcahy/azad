digraph MessagingArchitecture {
    rankdir=LR;
    nodesep=0.5;
    ranksep=0.8;
    node [shape=box, style="rounded,filled", fontname="Helvetica", margin="0.2,0.1"];
    edge [fontname="Helvetica", fontsize=10];

    // Graph Legend
    label="Legend:\nSolid lines = Persistent Connection (port.postMessage)\nDashed lines = One-off Message (chrome.runtime.sendMessage)";
    labelloc="t";
    labeljust="c";
    fontname="Helvetica";
    fontsize=11;
    fontcolor="#555555";

    // Nodes
    SW [label="ServiceWorker\n(background.ts)", fillcolor="#f0f0ff", color="#a0a0ff", penwidth=2];
    CP [label="Control Popup\n(control.ts)", fillcolor="#e0f7fa", color="#00acc1", penwidth=2];
    Content [label="Content Pages\n(inject, cachestuff, signin, etc)", fillcolor="#f1f8e9", color="#7cb342", penwidth=2];

    // Connections (Solid Lines)
    CP -> SW [label=" Commands:\nclear_cache, force_logout,\nshow_payment_ui, abort", color="#0055aa"];
    SW -> CP [label=" Status updates,\nAuth check results", color="#0055aa"];

    SW -> Content [label=" Broadcast:\ndump_order_detail", color="#00aa00"];
    Content -> SW [label=" keepalive\n(prevents suspension)", color="#00aa00"];

    // No-connection (Dotted Lines)
    Content -> SW [style=dashed, label=" Cache Ops:\nget, set, getkeys, remove\n(via cachestuff.ts)", color="#d32f2f"];
    SW -> Content [style=dashed, label=" Cache hits/misses\n(via responseCallback)", color="#d32f2f"];
    
    Content -> SW [style=dashed, label=" Auth Utils:\nopen_tab, remove_cookie\n(via signin.ts)", color="#d32f2f"];


}
